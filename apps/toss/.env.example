# 피키 앱인토스 미니앱 환경변수
# WebView는 자체 오리진(https://picky.apps.tossmini.com)이 API가 아니므로,
# 배포된 picky API 오리진을 반드시 주입해야 해요.

# 배포된 picky API 오리진 (예: Vercel 백엔드). 경로 /api 는 자동으로 붙어요.
VITE_API_BASE_URL=https://picky-olive.vercel.app

# 외부 공유 링크가 열릴 공개 웹 오리진 (OG 미리보기 포함).
VITE_PUBLIC_APP_URL=https://picky-olive.vercel.app

# (선택) 공유/OG 전용 오리진. 미설정 시 VITE_PUBLIC_APP_URL 사용.
# VITE_SHARE_BASE_URL=https://picky-olive.vercel.app

# (선택) 동의 기반 프로필(getConsentedUserData) — 콘솔 '유저정보 불러오기'에서 발급한 cud_ 키.
# 미설정/빈 값이면 '토스 프로필 불러오기' 옵트인 버튼이 숨겨져요(기능 비활성).
# 운영 .ait 빌드 시 인라인으로 주입: VITE_TOSS_CUD_PROFILE_KEY=cud_... pnpm build:toss
# VITE_TOSS_CUD_PROFILE_KEY=cud_콘솔에서_발급한_키

# (선택) 인앱 배너 광고 그룹 ID — 콘솔(앱인토스 → 인앱 광고)에서 발급해 주입해요.
# 미설정 시: 개발 빌드는 테스트 광고, 운영 빌드는 광고 미노출(빈 슬롯 방지).
# 실제 광고 ID로 개발 테스트하면 정책 위반이니 운영 빌드에만 넣어 주세요.
# - VITE_TOSS_AD_GROUP_ID       : 리스트형(가로 배너) 광고 그룹 ID
# - VITE_TOSS_FEED_AD_GROUP_ID  : 피드형(네이티브 이미지) 광고 그룹 ID (미설정 시 위 배너 ID로 폴백)
# VITE_TOSS_AD_GROUP_ID=
# VITE_TOSS_FEED_AD_GROUP_ID=

# 참고: 미니앱이 API를 호출하려면 picky API 서버의 CORS 허용 목록에
#   https://picky.apps.tossmini.com (실서비스)
#   https://picky.private-apps.tossmini.com (QR 테스트)
# 두 오리진을 추가해야 해요.
