# Frontend API base URL
# 예시:
# - https://picky-olive-api.vercel.app/api
# - https://your-api-domain.example.com/api
# - https://your-api-domain.example.com
VITE_API_BASE_URL=https://picky-olive-api.vercel.app/api

# 운영에서 요청 추적이 필요하면 쿼리 파라미터로 활성화
