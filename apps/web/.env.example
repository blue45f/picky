# Frontend API base URL
# 예시:
# - (비워 두면) 현재 프론트 호스트의 /api로 동작합니다.
# - 외부 API를 별도로 쓰려면 https://your-api-domain.example.com/api 형태로 지정하세요.
VITE_API_BASE_URL=

# 운영에서 요청 추적이 필요하면 쿼리 파라미터로 활성화
# https://picky-olive.vercel.app/auth/guest?api_debug=true
# 또는 브라우저 콘솔에서: localStorage.setItem('picky_api_debug', 'true')
