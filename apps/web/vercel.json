{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/create", "destination": "/" },
    { "source": "/design", "destination": "/" },
    { "source": "/auth/:path*", "destination": "/" },
    { "source": "/poll/:id", "destination": "/" },
    { "source": "/poll/:id/:path*", "destination": "/" },
    { "source": "/:path*", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
