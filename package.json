{
  "name": "picky",
  "version": "0.1.0",
  "private": true,
  "description": "Picky - 까다로운 고민을 지인들에게 투표 링크로 빠르게 물어보는 투표 SNS 플랫폼",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=./apps/* --filter=!@picky/toss run dev",
    "dev:web": "pnpm --filter @picky/web run dev",
    "dev:api": "pnpm --filter @picky/api run dev",
    "dev:toss": "pnpm --filter @picky/toss run dev",
    "build": "pnpm exec turbo run build",
    "build:toss": "pnpm --filter @picky/toss run build",
    "lint": "eslint . && pnpm exec turbo run lint",
    "lint:strict": "eslint . --max-warnings=0",
    "lint:ci": "pnpm run lint:strict",
    "audit:security": "pnpm audit --audit-level high --ignore GHSA-2p57-rm9w-gvfp",
    "lint:security": "pnpm run lint:strict && pnpm run audit:security",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm exec turbo run test --concurrency=1",
    "check:shared": "node scripts/sync-toss-shared.mjs",
    "sync:toss-shared": "node scripts/sync-toss-shared.mjs --write",
    "verify": "pnpm run check:shared && pnpm run format:check && pnpm run lint:ci && pnpm run typecheck && pnpm run test && pnpm run build",
    "verify:push": "pnpm run verify && pnpm run lint:security",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "esbuild": "0.27.7",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.26",
    "@picky/shared": "workspace:*",
    "@vercel/blob": "^2.4.1",
    "@vercel/kv": "^3.0.0",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "nestjs-zod": "^4.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
