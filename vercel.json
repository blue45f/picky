{
  "buildCommand": "pnpm build && node scripts/build-vercel-api-bundle.mjs",
  "outputDirectory": "apps/web/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "api/_serverless-api.js"
    }
  },
  "redirects": [
    {
      "source": "/share/:id",
      "destination": "/poll/:id",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api?path=:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    },
    {
      "source": "/audio/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
